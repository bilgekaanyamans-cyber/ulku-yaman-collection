# ══════════════════════════════════════════════════════════════
# Ülkü Yaman Collection — Ortam Değişkenleri
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur
# ══════════════════════════════════════════════════════════════

# ─── Veritabanı (Neon veya Supabase) ─────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/ulkuyaman?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="buraya-rastgele-uzun-bir-string-yaz"  # openssl rand -base64 32

# ─── Google OAuth ─────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxx"

# ─── Cloudinary (Görsel Yükleme) ─────────────────────────────
# cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── iyzico (Ödeme) ──────────────────────────────────────────
# merchant.iyzipay.com → Ayarlar → API Anahtarları
IYZICO_API_KEY="sandbox-xxxxx"
IYZICO_SECRET_KEY="sandbox-xxxxx"
IYZICO_BASE_URL="https://sandbox-api.iyzipay.com"  # Canlı: https://api.iyzipay.com

# ─── Resend (E-posta) ────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY="re_xxxxx"
RESEND_FROM_EMAIL="siparis@ulkuyaman.com"

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://ulkuyaman.com"
NEXT_PUBLIC_SITE_NAME="Ülkü Yaman Collection"
